; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Lemmings Clone"
config/description="A Lemmings puzzle game prototype — guide your lemmings to safety!"
config/version="0.1.0"
run/main_scene="res://scenes/menu/main_menu.tscn"
config/features=PackedStringArray("4.3")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://autoload/game_manager.gd"
LevelManager="*res://autoload/level_manager.gd"
SaveManager="*res://autoload/save_manager.gd"
AudioManager="*res://autoload/audio_manager.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[input_devices]

pointing/emulate_touch_from_mouse=true

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
environment/defaults/default_clear_color=Color(0, 0, 0, 1)
